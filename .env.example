# Copy this file to .env and fill in your ENTSO-E security token.
# Get one at: https://transparency.entsoe.eu → My Account → Security Token
ENTSOE_API_KEY=your_token_here

# --- report stage (daily forecast email) ---
# Required when running `ddkast report`. Other stages ignore these.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password_or_app_password
SMTP_USE_TLS=true
EMAIL_FROM=forecasts@example.com
EMAIL_TO=recipient@example.com
